# ==============================================
# Kafundo — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ==============================================

# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Base de données PostgreSQL
POSTGRES_DB=kafundo
POSTGRES_USER=kafundo
POSTGRES_PASSWORD=changeme_db_password
DATABASE_URL=postgresql+asyncpg://kafundo:changeme_db_password@postgres:5432/kafundo
DATABASE_SYNC_URL=postgresql://kafundo:changeme_db_password@postgres:5432/kafundo

# Redis
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# Email (Brevo / SendGrid / SMTP standard)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-api-key
EMAIL_FROM=noreply@kafundo.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=652998119352-15h4dcof3tujdtft0ceckk8bvllkqirt.apps.googleusercontent.com

# Google OAuth
GOOGLE_CLIENT_ID=652998119352-15h4dcof3tujdtft0ceckk8bvllkqirt.apps.googleusercontent.com 

# LLM pour enrichissement (optionnel - Phase V2)
MISTRAL_API_KEY=

OPENAI_API_KEY=sk-proj-VOTRE_CLE_OPENAI_ICI
AI_REWRITE_PROVIDER=openai
AI_REWRITE_MODEL=gpt-4o-mini
AI_REWRITE_TIMEOUT_SECONDS=45

# Sources tierces (optionnel)
LES_AIDES_API_IDC=
AIDES_ENTREPRISES_API_ID=
AIDES_ENTREPRISES_API_KEY=

# Sentry (optionnel)
SENTRY_DSN=

# Collecte
DEFAULT_REQUEST_TIMEOUT=30
DEFAULT_REQUEST_DELAY=1.5
MAX_RETRIES=3
AUTO_PUBLISH_MIN_CONFIDENCE=55

# Billing / Stripe
STRIPE_SECRET_KEY=sk_live_replace-with-your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-stripe-webhook-secret
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_EXPERT=
STRIPE_PRICE_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=https://kafundo.hamed-vps.cloud/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://kafundo.hamed-vps.cloud/billing?checkout=cancel
STRIPE_PORTAL_RETURN_URL=https://kafundo.hamed-vps.cloud/billing
