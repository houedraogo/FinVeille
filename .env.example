# ==============================================
# FinVeille — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ==============================================

# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Base de données PostgreSQL
POSTGRES_DB=finveille
POSTGRES_USER=finveille
POSTGRES_PASSWORD=changeme_db_password
DATABASE_URL=postgresql+asyncpg://finveille:changeme_db_password@postgres:5432/finveille
DATABASE_SYNC_URL=postgresql://finveille:changeme_db_password@postgres:5432/finveille

# Redis
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# Email (Brevo / SendGrid / SMTP standard)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-api-key
EMAIL_FROM=noreply@finveille.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# LLM pour enrichissement (optionnel - Phase V2)
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Sources tierces (optionnel)
LES_AIDES_API_IDC=
AIDES_ENTREPRISES_API_ID=
AIDES_ENTREPRISES_API_KEY=

# Sentry (optionnel)
SENTRY_DSN=

# Collecte
DEFAULT_REQUEST_TIMEOUT=30
DEFAULT_REQUEST_DELAY=1.5
MAX_RETRIES=3
AUTO_PUBLISH_MIN_CONFIDENCE=55
