# ==============================================
# FinVeille — Variables d'environnement production
# Copier ce fichier en .env.production et remplir
# ==============================================

# Application
APP_ENV=production
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret

# Base de données PostgreSQL
POSTGRES_DB=finveille
POSTGRES_USER=finveille
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql+asyncpg://finveille:replace-with-a-strong-db-password@postgres:5432/finveille
DATABASE_SYNC_URL=postgresql://finveille:replace-with-a-strong-db-password@postgres:5432/finveille

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379/0

# Email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@your-domain.com

# Frontend / Reverse proxy
NEXT_PUBLIC_API_URL=https://your-domain.com
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com

# APIs tierces
OPENAI_API_KEY=
MISTRAL_API_KEY=
LES_AIDES_API_IDC=
AIDES_ENTREPRISES_API_ID=
AIDES_ENTREPRISES_API_KEY=

# Collecte
DEFAULT_REQUEST_TIMEOUT=30
DEFAULT_REQUEST_DELAY=1.5
MAX_RETRIES=3
AUTO_PUBLISH_MIN_CONFIDENCE=55
