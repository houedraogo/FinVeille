# ==============================================
# Kafundo — Variables d'environnement production
# Copier ce fichier en .env.production et remplir
# ==============================================

# Application
APP_ENV=production
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret

# Base de données PostgreSQL
POSTGRES_DB=kafundo
POSTGRES_USER=kafundo
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql+asyncpg://kafundo:replace-with-a-strong-db-password@postgres:5432/kafundo
DATABASE_SYNC_URL=postgresql://kafundo:replace-with-a-strong-db-password@postgres:5432/kafundo

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379/0

# Email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@your-domain.com

# Frontend / Reverse proxy
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=652998119352-15h4dcof3tujdtft0ceckk8bvllkqirt.apps.googleusercontent.com
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com
PUBLIC_APP_URL=https://your-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=652998119352-15h4dcof3tujdtft0ceckk8bvllkqirt.apps.googleusercontent.com 

# APIs tierces
MISTRAL_API_KEY=
LES_AIDES_API_IDC=
AIDES_ENTREPRISES_API_ID=
AIDES_ENTREPRISES_API_KEY=

OPENAI_API_KEY=sk-proj-VOTRE_CLE_OPENAI_ICI
AI_REWRITE_PROVIDER=openai
AI_REWRITE_MODEL=gpt-4o-mini
AI_REWRITE_TIMEOUT_SECONDS=45

# Collecte
DEFAULT_REQUEST_TIMEOUT=30
DEFAULT_REQUEST_DELAY=1.5
MAX_RETRIES=3
AUTO_PUBLISH_MIN_CONFIDENCE=55

# Billing / Stripe
STRIPE_SECRET_KEY=sk_live_replace-with-your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-stripe-webhook-secret
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_EXPERT=
STRIPE_PRICE_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=https://kafundo.hamed-vps.cloud/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://kafundo.hamed-vps.cloud/billing?checkout=cancel
STRIPE_PORTAL_RETURN_URL=https://kafundo.hamed-vps.cloud/billing

# Observabilite / backups
SENTRY_DSN=
BACKUP_RETENTION_DAYS=14

